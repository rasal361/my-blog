<section class="container section-tight">
  <div class="newsletter">
    <div>
      <p class="eyebrow">Letters</p>
      <h2>Occasional notes from the trail, desk, and bookshelf.</h2>
      <p>No noise. Just new essays, photo sets, and reading notes when they are ready.</p>
    </div>
    <form action="mailto:hello@naimul.net" method="post" enctype="text/plain">
      <label class="sr-only" for="newsletter-email">Email address</label>
      <input class="input" id="newsletter-email" name="email" type="email" placeholder="you@example.com" required />
      <button class="button" type="submit">Subscribe</button>
    </form>
  </div>
</section>
